<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} | Actionable Books</title>
  <meta name="description" content="{{ description }}">
  <meta property="og:title" content="{{ title }} | Actionable Books">
  <meta property="og:description" content="{{ description }}">
  <meta name="robots" content="index, follow">
  {% if page.url %}<link rel="canonical" href="https://www.actionablebooks.com{{ page.url }}">{% endif %}
  <link href="/assets/css/normalize.css" rel="stylesheet" type="text/css">
  <link href="/assets/css/webflow.css" rel="stylesheet" type="text/css">
  <link href="/assets/css/actionable-books.webflow.css" rel="stylesheet" type="text/css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-1JN72T7V0Y"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-1JN72T7V0Y');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3649517228913627" crossorigin="anonymous"></script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title }}",
    "description": "{{ description }}",
    "url": "https://www.actionablebooks.com{{ page.url }}",
    "publisher": {
      "@type": "Organization",
      "name": "Actionable Books",
      "url": "https://www.actionablebooks.com"
    }
  }
  </script>
  <style>
  *, *::before, *::after { box-sizing: border-box; }
  body { margin: 0; font-family: Georgia, 'Times New Roman', serif; color: #2d2d2d; background: #fafaf8; }
  .guide-container { max-width: 860px; margin: 0 auto; padding: 0 1.5rem; }
  .guide-site-header { background: #1a2e3b; color: #fff; padding: 1rem 0; }
  .guide-site-header .guide-container { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
  .guide-logo { color: #fff; font-weight: 700; font-size: 1.1rem; text-decoration: none; letter-spacing: -0.01em; font-family: -apple-system, sans-serif; }
  .guide-nav a { color: rgba(255,255,255,0.8); text-decoration: none; margin-left: 1.5rem; font-size: 0.9rem; font-family: -apple-system, sans-serif; }
  .guide-nav a:hover { color: #fff; }
  .guide-hero { background: linear-gradient(135deg, #1a2e3b 0%, #2c5364 100%); color: #fff; padding: 3rem 0 2.5rem; }
  .guide-breadcrumb { font-size: 0.8rem; opacity: 0.7; margin-bottom: 0.75rem; font-family: -apple-system, sans-serif; }
  .guide-breadcrumb a { color: #fff; }
  .guide-h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 700; margin: 0 0 0.75rem; line-height: 1.25; font-family: Georgia, serif; }
  .guide-description { font-size: 1.1rem; opacity: 0.9; margin: 0; line-height: 1.6; max-width: 680px; }
  .guide-body { padding: 2.5rem 1.5rem 4rem; }
  .guide-article { max-width: 720px; }
  .guide-article h2 { font-size: 1.5rem; font-weight: 700; margin: 2.5rem 0 0.75rem; color: #1a2e3b; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.4rem; font-family: Georgia, serif; }
  .guide-article h3 { font-size: 1.2rem; font-weight: 600; margin: 1.75rem 0 0.5rem; color: #1a2e3b; font-family: Georgia, serif; }
  .guide-article h4 { font-size: 0.85rem; font-weight: 600; margin: 1.25rem 0 0.4rem; color: #374151; font-family: -apple-system, sans-serif; text-transform: uppercase; letter-spacing: 0.05em; }
  .guide-article p { margin-bottom: 1.1rem; line-height: 1.75; color: #374151; font-size: 1rem; }
  .guide-article ul, .guide-article ol { margin: 0.75rem 0 1.25rem 1.5rem; }
  .guide-article li { margin-bottom: 0.5rem; line-height: 1.65; color: #374151; }
  .guide-article strong { color: #1a2e3b; }
  .guide-article a { color: #1a6b9a; }
  .guide-cta { background: linear-gradient(135deg, #1a2e3b 0%, #2c5364 100%); color: #fff; padding: 1.75rem 2rem; border-radius: 8px; text-align: center; margin: 2.5rem 0; }
  .guide-cta h3 { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; color: #fff; font-family: Georgia, serif; }
  .guide-cta p { color: rgba(255,255,255,0.9); margin-bottom: 1rem; font-family: -apple-system, sans-serif; font-size: 0.95rem; }
  .guide-cta a { display: inline-block; background: #e8a000; color: #fff; font-weight: 700; padding: 0.75rem 1.75rem; border-radius: 6px; text-decoration: none; font-family: -apple-system, sans-serif; }
  .guide-cta a:hover { background: #c87f00; }
  .related-guides { background: #f0f4f8; border-left: 4px solid #1a6b9a; padding: 1.25rem 1.5rem; margin-top: 3rem; border-radius: 0 6px 6px 0; }
  .related-guides h3 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin-bottom: 0.75rem; font-family: -apple-system, sans-serif; }
  .related-guides ul { margin: 0; padding: 0; list-style: none; }
  .related-guides li { margin-bottom: 0.5rem; }
  .related-guides a { color: #1a6b9a; font-weight: 500; font-family: -apple-system, sans-serif; }
  .guide-book-card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 1.25rem; margin: 1rem 0; background: #fff; display: flex; gap: 1rem; align-items: flex-start; }
  .guide-book-card-info h4 { margin: 0 0 0.25rem; font-size: 1rem; color: #1a2e3b; font-family: Georgia, serif; text-transform: none; letter-spacing: 0; }
  .guide-book-card-info .author { color: #6b7280; font-size: 0.85rem; margin-bottom: 0.5rem; font-style: italic; }
  .guide-book-card-info p { margin: 0; font-size: 0.9rem; }
  .guide-footer { background: #1a2e3b; color: rgba(255,255,255,0.7); padding: 2rem 0; margin-top: 3rem; }
  .guide-footer-links { margin-bottom: 1rem; }
  .guide-footer-links a { color: rgba(255,255,255,0.7); text-decoration: none; margin-right: 1.5rem; font-size: 0.85rem; font-family: -apple-system, sans-serif; }
  .guide-footer-links a:hover { color: #fff; }
  .guide-copyright { font-size: 0.8rem; margin: 0; font-family: -apple-system, sans-serif; }
  </style>
</head>
<body>
  <div class="guide-site-header">
    <div class="guide-container">
      <a href="/" class="guide-logo">Actionable Books</a>
      <nav class="guide-nav">
        <a href="/summaries/">Book Summaries</a>
        <a href="/guides/">Guides</a>
        <a href="/blog/">Blog</a>
        <a href="/about/">About</a>
      </nav>
    </div>
  </div>

  <div class="guide-hero">
    <div class="guide-container">
      <p class="guide-breadcrumb"><a href="/">Home</a> › <a href="/guides/">Reading Guides</a> › {{ title }}</p>
      <h1 class="guide-h1">{{ title }}</h1>
      <p class="guide-description">{{ description }}</p>
    </div>
  </div>

  <div class="guide-container guide-body">
    <article class="guide-article">
      {{ content | safe }}
    </article>
  </div>

  <footer class="guide-footer">
    <div class="guide-container">
      <div class="guide-footer-links">
        <a href="/">Home</a>
        <a href="/summaries/">Book Summaries</a>
        <a href="/blog/">Blog</a>
        <a href="/about/">About</a>
      </div>
      <p class="guide-copyright">© 2025 Actionable Books. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
